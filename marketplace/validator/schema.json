{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Antigravity Plugin Manifest",
  "description": "Compatibility schema for flat Antigravity plugin.json manifests. scripts/validate_plugins.py is canonical.",
  "type": "object",
  "required": ["name", "version", "description"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+([-.][A-Za-z0-9.]+)?$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object"
        }
      ]
    },
    "repository": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
