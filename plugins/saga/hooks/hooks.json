{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${ANTIGRAVITY_PLUGIN_ROOT}/hooks/stale_main_session_hook.py\""
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${ANTIGRAVITY_PLUGIN_ROOT}/hooks/compact_spore_session_hook.py\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${ANTIGRAVITY_PLUGIN_ROOT}/hooks/precompact_spore_hook.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "replace_file_content|write_to_file|multi_replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${ANTIGRAVITY_PLUGIN_ROOT}/hooks/validate_json_hook.py\""
          }
        ]
      },
      {
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${ANTIGRAVITY_PLUGIN_ROOT}/hooks/pre_push_gate_hook.py\""
          }
        ]
      },
      {
        "matcher": "invoke_subagent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${ANTIGRAVITY_PLUGIN_ROOT}/hooks/team_spawn_residency_hook.py\""
          }
        ]
      },
      {
        "matcher": "replace_file_content|write_to_file|multi_replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${ANTIGRAVITY_PLUGIN_ROOT}/hooks/delegation_tripwire_hook.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${ANTIGRAVITY_PLUGIN_ROOT}/hooks/delegation_stop_audit_hook.py\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${ANTIGRAVITY_PLUGIN_ROOT}/hooks/delegation_stop_audit_hook.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${ANTIGRAVITY_PLUGIN_ROOT}/hooks/journal_nudge_hook.py\""
          }
        ]
      }
    ]
  }
}
